<addons>
<addon id="plugin.program.tools"
       name="Tools"
       version="1.0.0"
       provider-name="Agaton">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests"/>
    </requires>

    <extension point="xbmc.python.script" library="addon.py" />

    <extension point="xbmc.addon.metadata">
        <summary>Narzędzia</summary>
        <description>Narzędzie instalacyjne (Zależności/modułów), gdy nieaktywne aktywuj i kliknij 'Uruchom'</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>

</addon>

