<addon id="repository.Agaton111"
       name="Agaton Repo"
       version="1.0.0"
       provider-name="Agaton111">
    <extension point="xbmc.addon.repository">
        <dir>
            <info compressed="false">
                https://agaton111.github.io/repository.Agaton111/addons.xml
            </info>
            <checksum>
                https://agaton111.github.io/repository.Agaton111/addons.xml.md5
            </checksum>
            <datadir zip="true">
                https://agaton111.github.io/repository.Agaton111/repo/zips/
            </datadir>
        </dir>
    </extension>
</addon>

<addon id="script.epgagaton19" name="epgagaton" version="0.0.1" provider-name="Agaton">
  <requires>
     <import addon="script.module.pyxbmct" />
     <import addon="script.module.requests" />
  </requires>
  <extension point="xbmc.python.script" library="default.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <summary lang="en">Demo EPG</summary>
    <description lang="en">Pobiera opis filmu.</description>
      <assets>
        <icon>icon.png</icon>
    </assets>
  </extension>
      <extension point="kodi.context.item" library="default.py">
        <item>
            <label>[COLOR gold][B]Info 2 o filmie[/B][/COLOR]</label>
            <visible>True</visible>
        </item>
    </extension>

</addon>

