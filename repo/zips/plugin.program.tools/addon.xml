<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.program.tools"
       name="Tools Instalator"
       version="1.0.0"
       provider-name="Agaton">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests"/>		
    </requires>

    <extension point="xbmc.python.script" library="addon.py" />

    <extension point="xbmc.addon.metadata">
        <summary>Instalator nietypowych modułów</summary>
        <description>Narzędzie do pobierania różnych plików, instalacji modułów. Oraz instalacji plików language.pl_pl. Gdy nieaktywne aktywuj i kliknij -'Uruchom'</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>	  		
    </extension>

</addon>