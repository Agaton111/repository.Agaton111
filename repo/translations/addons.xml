<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="program.easyplayerswitch" name="Easy Player Switch" provider-name="DigiTalking" version="1.1.0">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <license>MIT</license>
        <source>https://gitlab.com/personal4143605/easy-player-switch</source>
        <summary lang="en_GB">Switch between VLC, custom player, and Kodi internal player easily.</summary>
        <summary lang="it_IT">Cambia player facilmente scegliendo tra VLC, player personalizzato e player interno di Kodi.</summary>
        <description lang="en_GB">This addon allows you to switch between VLC, custom player, and Kodi's internal player with a simple menu.</description>
        <description lang="it_IT">Questo addon consente di cambiare player scegliendo VLC, player personalizzato e player interno di Kodi tramite un semplice menù.</description>
        <description lang="it_IT">Questo addon consente di cambiare player scegliendo VLC, player personalizzato e player interno di Kodi tramite un semplice menù.</description>
        <description lang="pl_PL">Dodatek ten pozwala na zmianę odtwarzacza poprzez wybór VLC.Wybór niestandardowego odtwarzacza i wewnętrznego odtwarzacza Kodi ,jest za pomocą prostego menu.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.png</fanart>
        </assets>
    </extension>
</addon>

<addon id="slyguy.trailers" name="SlyGuy Trailers" provider-name="SlyGuy" version="0.0.40">
    <requires>
        <import addon="script.module.slyguy" version="0.86.20"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" start="login" />
    <extension point="kodi.context.item">
        <menu id="kodi.core.main">
        <item library="default.py">
            <label>$LOCALIZE[20410]</label>
            <visible>
                    [String.IsEqual(ListItem.DBType,movie) + String.Contains(Window(10000).Property(_slyguy_trailer_context_menu),1)] |
                    [String.IsEqual(ListItem.DBType,tvshow) + String.Contains(Window(10000).Property(_slyguy_trailer_context_menu),2)] |
                    [String.IsEqual(ListItem.DBType,season) + String.IsEqual(ListItem.Season,) + String.Contains(Window(10000).Property(_slyguy_trailer_context_menu),2)] |
                    [String.IsEqual(ListItem.DBType,season) + String.Contains(Window(10000).Property(_slyguy_trailer_context_menu),3)]
            </visible>
        </item>
        </menu>
    </extension>
    <extension point="xbmc.addon.metadata">
        <description lang="en">An add-on to enhance the Kodi trailer experience</description>
        <reuselanguageinvoker>true</reuselanguageinvoker>
        <license></license>
        <language></language>
        <website></website>
        <news>yt_dlp to 2026.02.04. yt_dlp_ejs to 0.4.0</news>
        <assets>
        <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
</addons>
