<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.polskatv"
       name="Polska TV (darmowa)"
       version="1.0.0"
       provider-name="Agat">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="inputstream.adaptive" version="20.3.0"/>
        <import addon="script.module.beautifulsoup4" version="4.0.0"/>
        <import addon="script.module.requests" version="2.0.0"/>
        <import addon="script.module.yt_dlp" version="2023.11.16"/>
        <import addon="script.module.inputstreamhelper" version="0.8.2"/>		
    </requires>

    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Polska TV agaton </summary>
        <description>Dodatek testowy z kilkoma darmowymi kanałami i poprawionym odtwarzaniem HLS/MP4.</description>
        <language>pl</language>
        <platform>all</platform>
	  <assets>
		<icon>icon.png</icon>
		<fanart>fanart.jpg</fanart>
	  </assets>		
    </extension>
</addon>
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.epgagaton19" name="epgagaton" version="0.0.1" provider-name="Agaton">
  <requires>
     <import addon="script.module.pyxbmct" />
     <import addon="script.module.requests" />
  </requires>
  <extension point="xbmc.python.script" library="default.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <summary lang="en">Demo EPG</summary>
    <description lang="en">Pobiera opis do filmu. Integruje się z innymi wtyczkami, przez menu kontekstowe. Może pracować też samodzielnie.</description>
      <assets>
        <icon>icon.png</icon>
    </assets>		
  </extension>
      <extension point="kodi.context.item" library="default.py">
        <item>
            <label>[COLOR gold][B]Info 2 o filmie[/B][/COLOR]</label>
            <visible>True</visible>
        </item>
    </extension>
      
</addon>
