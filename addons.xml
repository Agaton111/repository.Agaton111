<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.program.tools"
       name="Tools"
       version="1.0.0"
       provider-name="Agaton">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.python.script" library="addon.py" />

    <extension point="xbmc.addon.metadata">
        <summary>Narzędzia</summary>
        <description>Proste narzędzia instalacyjne</description>
        <platform>all</platform>
    </extension>

</addon>
<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<addon id="plugin.video.toya" name="TOYA GO 2026" version="1.0.1" provider-name="lg">
<requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests" />
    <import addon="script.module.inputstreamhelper" />
</requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
 	<extension point="xbmc.addon.metadata">
        <description lang="pl">TOYA GO 2026</description>
        <disclaimer lang="pl">TOYA GO 2026
        </disclaimer>
        <summary lang="en">TOYA GO 2026</summary>
        <description lang="en">TOYA GO 2026</description>
        <disclaimer lang="en">TOYA GO 2026
        </disclaimer>
        <language>pl</language>
        <platform>all</platform>
        <license>GNU GENERAL PUBLIC LICENSE. Version 2, June 1991</license>
        <website></website>
        <assets>
            <icon>icon.png</icon>
        </assets>
        <reuselanguageinvoker>true</reuselanguageinvoker>
    </extension>
</addon>
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.epgagaton19" name="epgagaton" version="0.0.1" provider-name="Agaton">
  <requires>
     <import addon="script.module.pyxbmct" />
     <import addon="script.module.requests" />
  </requires>
  <extension point="xbmc.python.script" library="default.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <summary lang="en">Demo EPG</summary>
    <description lang="en">Pobiera opis filmu.</description>
      <assets>
        <icon>icon.png</icon>
    </assets>		
  </extension>
      <extension point="kodi.context.item" library="default.py">
        <item>
            <label>[COLOR gold][B]Info 2 o filmie[/B][/COLOR]</label>
            <visible>True</visible>
        </item>
    </extension>
      
</addon>
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.tvprogram19" name="tvprogram19" version="0.0.2" provider-name="Agaton">
  <requires>
     <import addon="xbmc.python" version="3.0.0"/>
     <import addon="script.module.requests" />   
     <import addon="script.module.pyxbmct"/>
    
  </requires>
  <extension point="xbmc.python.script" library="default.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <summary lang="en">Demo TV EPG</summary>
    <description lang="en">Pobiera program TV.</description>
      <assets>
        <icon>icon.png</icon>
    </assets>	
  </extension>
      <extension point="kodi.context.item" library="default.py">
        <item>
            <label>[COLOR cyan][B]Info TV program[/B][/COLOR]</label>
            <visible>True</visible>
        </item>

    </extension>
      
</addon>
</addons>
